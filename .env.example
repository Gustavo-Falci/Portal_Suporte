# =============================================================
# .env.example — template SEM segredos. Copie para .env e preencha.
#   cp .env.example .env
# NUNCA commitar o .env real (está no .gitignore).
# =============================================================

# --- Núcleo Django ---
# Local: True. Produção: False (fail-safe: default já é False).
DEBUG=False
# Gerar nova: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
# Lista separada por vírgula. Ex local: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Banco de Dados (Oracle/Postgres conforme settings) ---
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=

# --- Email (listener + notificações) ---
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- Integração IBM Maximo ---
MAXIMO_API_URL=
MAXIMO_API_URL_LOG=
MAXIMO_API_KEY=
# Validação TLS do Maximo. Local: False. Prod: True (quando houver CA bundle).
VERIFY=True

# --- Storage Oracle Cloud (OCI / S3-compat) ---
# True ativa storage remoto; False usa disco local.
USE_S3=False
OCI_ACCESS_KEY=
OCI_SECRET_KEY=
OCI_BUCKET_NAME=
OCI_REGION_NAME=
OCI_ENDPOINT_URL=

# --- Segurança ---
# Path secreto do admin. Default 'admin/'. Prod: usar valor não-óbvio.
ADMIN_URL=admin/
# Content-Security-Policy em modo enforce. Prod: True.
CSP_ENFORCE=False

# --- URLs ---
# Base usada em links de e-mail. Default deriva de DEBUG se vazio.
SITE_URL=
